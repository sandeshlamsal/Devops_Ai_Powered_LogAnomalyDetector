# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# AWS / LocalStack
AWS_DEFAULT_REGION=us-east-1

# CloudWatch target
LOG_GROUP=/microservice/payment-service
LOG_STREAM=application

# Emitter tuning
EMIT_INTERVAL_SEC=2

# Agent tuning
POLL_INTERVAL_SEC=15
LOG_BATCH_SIZE=20

# Set to true to use mock Claude responses (no API key needed — for testing)
CLAUDE_MOCK=false
